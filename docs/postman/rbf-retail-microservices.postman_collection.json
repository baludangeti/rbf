{
  "info": {
    "name": "RBF Retail Billing Microservices",
    "description": "Postman collection for pure Spring Boot Retail Billing and Financial System. Uses JWT and X-ORG-ID collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9101"
    },
    {
      "key": "jwtToken",
      "value": ""
    },
    {
      "key": "orgId",
      "value": "101"
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "invoiceId",
      "value": "1001"
    },
    {
      "key": "paymentId",
      "value": "1"
    },
    {
      "key": "holdReference",
      "value": "COUNTER-1-001"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const token = json.token || (json.data && json.data.token);",
                  "if (token) {",
                  "  pm.collectionVariables.set('jwtToken', token);",
                  "}",
                  "",
                  "const orgId = json.orgId || json.org_id || (json.data && (json.data.orgId || json.data.org_id));",
                  "if (orgId) {",
                  "  pm.collectionVariables.set('orgId', String(orgId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Validates user credentials and stores JWT token into collection variable `jwtToken`."
          },
          "response": []
        }
      ]
    },
